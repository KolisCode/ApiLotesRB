generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Lote {
  id          Int        @id @default(autoincrement())
  numero      String     @unique
  slug        String?    @unique
  manzana     String
  area        Float
  precio      Float
  ubicacion   String
  estado      EstadoLote @default(disponible)
  descripcion String?
  imagen      String?
  latitud     Float?
  longitud    Float?
  servicios   Servicio[]
  contactos   Contacto[]
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
}

model Servicio {
  id     Int    @id @default(autoincrement())
  nombre String
  icono  String
  lote   Lote   @relation(fields: [loteId], references: [id], onDelete: Cascade)
  loteId Int
}

model Contacto {
  id        Int      @id @default(autoincrement())
  nombre    String
  email     String?
  telefono  String?
  mensaje   String
  loteId    Int?
  lote      Lote?    @relation(fields: [loteId], references: [id], onDelete: SetNull)
  leido     Boolean  @default(false)
  createdAt DateTime @default(now())
}

model Admin {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  password  String
  nombre    String
  createdAt DateTime @default(now())
}

/// Configuración editable del sitio público (fila única, id = 1).
/// La administra el panel; el front la consume para no depender de textos hardcodeados.
model SiteConfig {
  id             Int      @id @default(1)
  // Contacto / footer
  whatsappNumber String   @default("573000000000")
  telefono       String   @default("")
  email          String   @default("")
  direccion      String   @default("")
  horario        String   @default("")
  // Branding
  marca          String   @default("LotesRB")
  tagline        String   @default("")
  // Hero / home
  heroEyebrow    String   @default("")
  heroTitulo     String   @default("")
  heroSubtitulo  String   @default("")
  heroImagen     String?
  // Lista de ventajas ("¿por qué elegirnos?"): [{ icono, titulo, desc }]
  ventajas       Json     @default("[]")
  // Página Proyecto
  proyectoMunicipio   String @default("")
  proyectoNombre      String @default("")
  proyectoDescripcion String @default("")
  distancias          Json   @default("[]")   // [{ icono, lugar, detalle }]
  infraestructura     Json   @default("[]")   // [{ icono, nombre }]
  pasos               Json   @default("[]")   // [{ icono, titulo, desc }]
  financiacionTitulo  String @default("")
  financiacionTexto   String @default("")
  updatedAt      DateTime @updatedAt
}

enum EstadoLote {
  disponible
  reservado
  vendido
}
